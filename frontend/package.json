{
  "name": "asset-inventory-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "vite",
    "dev": "vite",
    "build": "vite build",
    "test": "jest --passWithNoTests --config jest.config.cjs",
    "test:e2e": "PW_BACKEND_URL=http://127.0.0.1:5002 playwright test",
    "test:e2e:smoke": "PW_BACKEND_URL=http://127.0.0.1:5002 playwright test --grep @smoke",
    "test:e2e:full": "PW_BACKEND_URL=http://127.0.0.1:5002 playwright test",
    "test:e2e:headed": "PW_BACKEND_URL=http://127.0.0.1:5002 playwright test --headed",
    "test:e2e:ci": "PW_BACKEND_URL=http://127.0.0.1:5002 playwright test --reporter=line",
    "test:e2e:ci:smoke": "PW_BACKEND_URL=http://127.0.0.1:5002 playwright test --grep @smoke --reporter=line",
    "test:e2e:ci:full": "PW_BACKEND_URL=http://127.0.0.1:5002 playwright test --reporter=line",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@reduxjs/toolkit": "^1.9.5",
    "axios": "^1.4.0",
    "jspdf": "^2.5.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hot-toast": "^2.6.0",
    "react-redux": "^8.0.5",
    "react-router-dom": "^6.14.0",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.22.0",
    "@babel/preset-react": "^7.22.0",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^14.0.0",
    "@testing-library/user-event": "^14.6.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "autoprefixer": "^10.4.27",
    "babel-jest": "^29.6.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.5.2",
    "jest": "^29.6.0",
    "jest-environment-jsdom": "28.1.3",
    "postcss": "^8.5.9",
    "tailwindcss": "^4.2.2",
    "vite": "^5.0.0"
  }
}
